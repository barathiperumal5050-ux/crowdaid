# ══════════════════════════════════════
# CROWDAID — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ══════════════════════════════════════

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/crowdaid

# JWT Secret — make this a long random string
JWT_SECRET=crowdaid_super_secret_key_change_this_to_random_string_2025

# Twilio credentials (for OTP + SMS)
# Get from: https://console.twilio.com
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token_here
TWILIO_PHONE=+1234567890

# Your frontend URL (change in production)
CLIENT_URL=http://localhost:5500

# Server port
PORT=5000
